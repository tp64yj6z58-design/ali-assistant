{
  "version": 2,
  "buildCommand": "npm run check",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/recommend",
      "destination": "/api/recommend"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
